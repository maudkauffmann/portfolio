{% extends 'base.html.twig' %}

{% block body %}
    <main class="container-fluid p-0">
        <section id="hero" class="full-section" style="min-height: 75vh; padding-top: 120px; padding-bottom: 50px;">
            <p class="text-gold mb-3 font-monospace">Bienvenue sur mon portfolio</p>
            <h1 class="display-1 text-light fw-bold" style="font-family: 'Playfair Display';">Maud Kauffmann.</h1>
            <div class="mt-4" style="max-width: 580px;">
                <p class="lead text-slate">Étudiante en <span class="text-gold">IUT Informatique</span>. Je transforme des idées complexes en expériences numériques accessibles.</p>
            </div>
        </section>

        <section id="about" class="full-section" style="min-height: auto; padding-top: 50px; padding-bottom: 80px; scroll-margin-top: 100px;">
            <h3 class="section-heading mb-5 reveal"><span class="nav-number">01.</span>Mes Compétences</h3>
            <div class="row">
                <div class="col-lg-10">
                    <div class="reveal" style="transition-delay: 0.1s;">
                        <h5 class="text-gold font-monospace mb-4 small">/ Développement & Web <span class="text-slate opacity-50 ms-2">— Acquis en cursus IUT</span></h5>
                        <div class="d-flex flex-wrap gap-5 mb-5">
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-code-slash"></i></div>
                                <span class="skill-name">PHP / Symfony</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-terminal"></i></div>
                                <span class="skill-name">Python</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-filetype-html"></i></div>
                                <span class="skill-name">HTML / CSS</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-braces"></i></div>
                                <span class="skill-name">JS / React</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle">
                                    <span class="fw-bold text-gold" style="font-size: 1.8rem; font-family: 'Open Sans', sans-serif;">C++</span>
                                </div>
                                <span class="skill-name">C++</span>
                            </div>
                        </div>
                    </div>

                    <div class="reveal" style="transition-delay: 0.2s;">
                        <h5 class="text-gold font-monospace mb-4 small">/ Data & Systèmes <span class="text-slate opacity-50 ms-2">— Projets académiques</span></h5>
                        <div class="d-flex flex-wrap gap-5 mb-5">
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-database"></i></div>
                                <span class="skill-name">SQL / Oracle</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-ubuntu"></i></div>
                                <span class="skill-name">Linux</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-diagram-3"></i></div>
                                <span class="skill-name">Packet Tracer</span>
                            </div>
                        </div>
                    </div>

                    <div class="reveal" style="transition-delay: 0.3s;">
                        <h5 class="text-gold font-monospace mb-4 small">/ Langues <span class="text-slate opacity-50 ms-2">— Certifications</span></h5>
                        <div class="d-flex flex-wrap gap-5">
                            <div class="skill-item">
                                <div class="skill-circle flag-circle">
                                    <img src="https://flagcdn.com/w80/gb.png" alt="Certification Anglais C1">
                                </div>
                                <span class="skill-name">Anglais C1</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle flag-circle">
                                    <img src="https://flagcdn.com/w80/de.png" alt="Certification Allemand B2">
                                </div>
                                <span class="skill-name">Allemand B2</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="projects" class="full-section" style="min-height: auto; padding-top: 80px; padding-bottom: 80px;">
            <h3 class="section-heading mb-5 reveal"><span class="nav-number">02.</span> Mes Projets</h3>

            <div class="row mb-5 reveal"> <div class="col-12"> <div class="project-card">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <p class="text-gold mb-1 small font-monospace">Projet d'équipe</p>
                                <h4 class="text-light fw-bold">SacréeTech - Gestion d'association</h4>
                                <div class="project-description-box py-3 px-4 my-3">
                                    Application complète de gestion de membres et d'événements avec sécurité Symfony.
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    <span class="badge-skill">PHP / Symfony</span>
                                    <span class="badge-skill">JS / React</span>
                                    <span class="badge-skill">SQL / Oracle</span>
                                    <span class="badge-skill">Git / GitHub</span>
                                    <span class="badge-skill">Agile / Planner</span>
                                </div>
                            </div>
                            <div class="col-md-4 text-md-end">
                                <a href="https://github.com/maudkauffmann/sacreeTech_app.git" target="_blank" class="github-btn px-3 py-2">
                                    <i class="bi bi-github me-2"></i> GitHub
                                </a>
                            </div>
                        </div>
                    </div> </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-md-6 reveal">
                    <div class="project-card h-100 d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-controller text-gold fs-3"></i>
                                <h4 class="text-light fw-bold m-0">Catalogue Jeux</h4>
                            </div>
                            <a href="https://github.com/maudkauffmann/game_catalogue_app.git" target="_blank" class="github-btn py-1 px-2 small">
                                <i class="bi bi-github me-1"></i> GitHub
                            </a>
                        </div>
                        <div class="project-description-box py-3 px-3 mb-3">
                            <p class="small text-light m-0">Gestion et filtrage dynamique d'un catalogue de jeux via Doctrine.</p>
                        </div>
                        <div class="mt-auto d-flex flex-wrap gap-2">
                            <span class="badge-skill">PHP / Symfony</span>
                            <span class="badge-skill">SQL / Oracle</span>
                            <span class="badge-skill">Git / GitHub</span>
                            <span class="badge-skill">Agile / Planner</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 reveal" style="transition-delay: 0.2s;">
                    <div class="project-card h-100 d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-suit-spade-fill text-gold fs-3"></i>
                                <h4 class="text-light fw-bold m-0">Jeu du Solitaire</h4>
                            </div>
                            <a href="https://github.com/maudkauffmann/Jeu_solitaire.git" target="_blank" class="github-btn py-1 px-2 small">
                                <i class="bi bi-github me-1"></i> GitHub
                            </a>
                        </div>
                        <div class="project-description-box py-3 px-3 mb-3">
                            <p class="small text-light m-0">Utilisation d'une logique algorithmique complète en Python.</p>
                        </div>
                        <div class="mt-auto d-flex flex-wrap gap-2">
                            <span class="badge-skill">Python</span>
                            <span class="badge-skill">Git / GitHub</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-center mt-5 reveal">
                <a href="https://github.com/maudkauffmann" target="_blank" class="github-profile-btn">
                    <i class="bi bi-github me-2"></i> Voir plus de projets sur GitHub
                </a>
            </div>
        </section>

        <section id="contact" class="full-section">
            <h2 class="section-heading d-inline-block">
                <span class="nav-number text-gold">03.</span>Me contacter
            </h2>
            <div class="reveal text-center mb-5">
                <p class="text-slate mx-auto mt-3" style="max-width: 600px; font-size: 1.1rem;">
                    Je suis actuellement à la recherche de nouvelles opportunités.
                    Que vous ayez une question ou que vous vouliez simplement me saluer, je vous répondrai avec plaisir !
                </p>
            </div>

            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-7">
                        <form action="https://formsubmit.co/maudkau@gmail.com" method="POST" class="glass-panel p-5 reveal">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="small text-gold mb-2 font-monospace">Nom</label>
                                    <input type="text" name="name" class="form-control custom-input" placeholder="Votre nom" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="small text-gold mb-2 font-monospace">Email</label>
                                    <input type="email" name="email" class="form-control custom-input" placeholder="Votre email" required>
                                </div>
                                <div class="col-12">
                                    <label class="small text-gold mb-2 font-monospace">Message</label>
                                    <textarea name="message" class="form-control custom-input" rows="5" placeholder="Votre message..." required></textarea>
                                </div>
                                <div class="col-12 text-center mt-4">
                                    <div class="col-12 text-center mt-4">
                                        <button type="submit" class="btn-big-gold px-5 py-3">Envoyer le message</button>
                                        <p class="text-slate mt-2" style="font-size: 0.75rem; opacity: 0.6;">
                                            En envoyant ce message, vous acceptez que vos données soient traitées pour répondre à votre demande.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </form>

                        <div class="reveal mt-5 pt-5 border-top border-dark-subtle">
                            <div class="text-center mb-5">
                                <p class="text-gold font-monospace small">
                                    Retrouvez-moi également ici :
                                </p>
                            </div>

                            <div class="d-flex flex-wrap justify-content-center gap-4">
                                <a href="tel:+33670566723" class="contact-pill">
                                    <i class="bi bi-telephone-fill me-2"></i> 06 70 56 67 23
                                </a>

                                <a href="https://www.linkedin.com/in/maud-kauffmann/" target="_blank" class="contact-pill">
                                    <i class="bi bi-linkedin me-2"></i> LinkedIn
                                </a>

                                <a href="mailto:maudkau@gmail.com" class="contact-pill">
                                    <i class="bi bi-envelope-fill me-2"></i> Mail Direct
                                </a>

                                <button onclick="copyEmail()" class="contact-pill">
                                    <i class="bi bi-clipboard-check me-2"></i> Copier l'email
                                </button>
                            </div>

                            <div id="copy-success" class="text-gold small text-center mt-4" style="display: none; font-family: 'SF Mono', monospace; letter-spacing: 0.5px;">
                                <i class="bi bi-check2-circle me-1"></i> Email copié dans le presse-papier !
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
{% endblock %}
