            </div>
        </section>

        <section id="projects" class="full-section" style="min-height: auto; padding-top: 80px; padding-bottom: 80px;">
            <h3 class="section-heading mb-5 reveal"><span class="nav-number">02.</span> Mes Projets</h3>

            <div class="project-card mb-5 reveal">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <p class="text-gold mb-1 small font-monospace">Projet Phare (Groupe)</p>
                        <h4 class="text-light fw-bold">SacréeTech - Gestion d'Association</h4>
                        <div class="project-description-box py-3 px-4 my-3">
                            Application complète de gestion de membres et d'évènements avec sécurité Symfony.
                        </div>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <span class="badge-skill">PHP / Symfony</span>
                            <span class="badge-skill">JS / React</span>
                            <span class="badge-skill">SQL / Oracle</span>
                            <span class="badge-skill">Git / GitHub</span>
                            <span class="badge-skill">Agile / Planner</span>
                        </div>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <a href="https://github.com/maudkauffmann/sacreeTech_app.git" target="_blank" class="github-btn px-3 py-2">
                            <i class="bi bi-github me-2"></i> GitHub
                        </a>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-md-6 reveal">
                    <div class="project-card h-100 d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-controller text-gold fs-3"></i>
                                <h4 class="text-light fw-bold m-0">Catalogue Jeux</h4>
                            </div>
                            <a href="https://github.com/maudkauffmann/game_catalogue_app.git" target="_blank" class="github-btn py-1 px-2 small">
                                <i class="bi bi-github me-1"></i> GitHub
                            </a>
                        </div>
                        <div class="project-description-box py-3 px-3 mb-3">
                            <p class="small text-light m-0">Gestion et filtrage dynamique d'un catalogue de jeux via Doctrine.</p>
                        </div>
                        <div class="mt-auto d-flex flex-wrap gap-2">
                            <span class="badge-skill">PHP / Symfony</span>
                            <span class="badge-skill">SQL / Oracle</span>
                            <span class="badge-skill">Git / GitHub</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 reveal" style="transition-delay: 0.2s;">
                    <div class="project-card h-100 d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-suit-spade-fill text-gold fs-3"></i>
                                <h4 class="text-light fw-bold m-0">Jeu du Solitaire</h4>
                            </div>
                            <a href="https://github.com/maudkauffmann/Jeu_solitaire.git" target="_blank" class="github-btn py-1 px-2 small">
                                <i class="bi bi-github me-1"></i> GitHub
                            </a>
                        </div>
                        <div class="project-description-box py-3 px-3 mb-3">
                            <p class="small text-light m-0">Utilisation d'une logique algorithmique complète en Python.</p>
                        </div>
                        <div class="mt-auto d-flex flex-wrap gap-2">
                            <span class="badge-skill">Python</span>
                            <span class="badge-skill">Git / GitHub</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5 reveal">
                <a href="https://github.com/maudkauffmann" target="_blank" class="github-profile-btn py-3 px-5">
                    <i class="bi bi-github me-2"></i> Voir plus de projets sur GitHub
                </a>
            </div>
        </section>

        <section id="contact" class="full-section reveal" style="min-height: auto; padding-top: 80px; padding-bottom: 120px; position: relative;">
            <div class="row justify-content-center mt-5">
                <div class="col-md-8">
                    <form action="https://formsubmit.co/maudkau@gmail.com" method="POST" class="project-card p-4">
                        <input type="hidden" name="_subject" value="Nouveau message de votre Portfolio !">
                        <input type="hidden" name="_template" value="table">
                        <input type="hidden" name="_next" value="{{ url('app_home') }}"> <div class="row g-3">
                            <div class="col-md-6 text-start">
                                <label class="text-gold small font-monospace mb-2">Votre Nom</label>
                                <input type="text" name="name" class="form-control bg-dark text-light border-secondary" required placeholder="Nom Prénom">
                            </div>
                            <div class="col-md-6 text-start">
                                <label class="text-gold small font-monospace mb-2">Votre Email</label>
                                <input type="email" name="email" class="form-control bg-dark text-light border-secondary" required placeholder="exemple@mail.com">
                            </div>
                            <div class="col-12 text-start">
                                <label class="text-gold small font-monospace mb-2">Message</label>
                                <textarea name="message" rows="4" class="form-control bg-dark text-light border-secondary" required placeholder="Votre projet ou proposition..."></textarea>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn-big-gold w-100 py-3">
                                    <i class="bi bi-send-fill me-2"></i> Envoyer le message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-4 mt-4">
                <a href="tel:+33600000000" class="text-slate small text-decoration-none">
                    <i class="bi bi-telephone me-1"></i> Appeler directement
                </a>
                <span class="text-slate opacity-25">|</span>
                <button onclick="copyEmail()" class="btn btn-link text-slate small text-decoration-none p-0">
                    <i class="bi bi-clipboard me-1"></i> Copier l'email
                </button>
            </div>
        </section>

        <script>
            function copyEmail() {
                const email = "maudkau@gmail.com";
                navigator.clipboard.writeText(email).then(() => {
                    const successMsg = document.getElementById('copy-success');
                    successMsg.style.display = 'block';
                    setTimeout(() => {
                        successMsg.style.display = 'none';
                    }, 3000);
                });
            }

            function reveal() {
                const reveals = document.querySelectorAll(".reveal");

                for (let i = 0; i < reveals.length; i++) {
                    const windowHeight = window.innerHeight;
                    const elementTop = reveals[i].getBoundingClientRect().top;
                    const elementVisible = 100;

                    if (elementTop < windowHeight - elementVisible) {
                        reveals[i].classList.add("active");
                    }
                }
            }

            window.addEventListener("scroll", reveal);
            window.addEventListener("load", reveal);
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function () {
                    setTimeout(reveal, 200);
                    setTimeout(reveal, 500);
                    setTimeout(reveal, 1000);
                });
            });
        </script>
    </main>
{% endblock %}
