                            </div>
                            <div class="skill-item">
                                <div class="skill-circle">
                                    <span class="fw-bold text-gold" style="font-size: 1.8rem; font-family: 'Open Sans', sans-serif;">C++</span>
                                </div>
                                <span class="skill-name">C++</span>
                            </div>
                        </div>
                    </div>

                    <div class="reveal" style="transition-delay: 0.2s;">
                        <h5 class="text-gold font-monospace mb-4 small">/ Data & Systèmes</h5>
                        <div class="d-flex flex-wrap gap-5 mb-5">
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-database"></i></div>
                                <span class="skill-name">SQL / Oracle</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-ubuntu"></i></div>
                                <span class="skill-name">Linux</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-diagram-3"></i></div>
                                <span class="skill-name">Packet Tracer</span>
                            </div>
                        </div>
                    </div>

                    <div class="reveal" style="transition-delay: 0.3s;">
                        <h5 class="text-gold font-monospace mb-4 small">/ Gestion & Outils Techniques</h5>
                        <div class="d-flex flex-wrap gap-5">
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-git"></i></div>
                                <span class="skill-name">Git / GitHub</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-kanban"></i></div>
                                <span class="skill-name">Agile / Planner</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-file-earmark-text"></i></div>
                                <span class="skill-name">LaTeX / Word</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle"><i class="bi bi-cpu"></i></div>
                                <span class="skill-name">CAO (Charly)</span>
                            </div>
                        </div>
                    </div>

                    <div class="reveal" style="transition-delay: 0.4s;">
                        <h5 class="text-gold font-monospace mb-4 small mt-5">/ Langues</h5>
                        <div class="d-flex flex-wrap gap-5">
                            <div class="skill-item">
                                <div class="skill-circle flag-circle">
                                    <img src="https://flagcdn.com/w80/gb.png" alt="UK">
                                </div>
                                <span class="skill-name">Anglais C1</span>
                            </div>
                            <div class="skill-item">
                                <div class="skill-circle flag-circle">
                                    <img src="https://flagcdn.com/w80/de.png" alt="DE">
                                </div>
