<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Maud Kauffmann | Portfolio{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Playfair+Display:wght@700&family=Raleway:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">

    {% block stylesheets %}
        {{ importmap('app') }}
    {% endblock %}
</head>
<body>
{# templates/base.html.twig #}

<nav class="navbar fixed-top custom-nav">
    <div class="container-fluid px-md-5">
        <a class="navbar-brand d-flex align-items-center" href="{{ path('app_home') }}">
            <img src="{{ asset('img/logo.png') }}" alt="Logo Maud Kauffmann" height="40">
        </a>

        <div class="d-flex align-items-center">
            <ul class="navbar-nav d-flex flex-row align-items-center mb-0">
                <li class="nav-item mx-2">
                    <a class="nav-link" href="#about"><span class="nav-number">01.</span> Compétences</a>
                </li>
                <li class="nav-item mx-2">
                    <a class="nav-link" href="#projects"><span class="nav-number">02.</span> Projets</a>
                </li>
                <li class="nav-item mx-2">
                    <a class="nav-link" href="#contact"><span class="nav-number">03.</span> Contact</a>
                </li>
                <li class="nav-item ms-3">
                    <a href="{{ asset('document/Maud_Kauffmann_CV_web.pdf') }}"
                       class="btn-resume" target="_blank" rel="noopener noreferrer">
                        Mon CV
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

{% block body %}{% endblock %}

<footer class="text-center py-5 mt-5 opacity-50 font-open">
    <p class="small text-slate">© 2026 — Conçu et développé par Maud Kauffmann</p>
</footer>

{% block javascripts %}
    {{ importmap('app') }}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
</body>
</html>
