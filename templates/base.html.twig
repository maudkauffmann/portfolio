{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function handleReveal() {
            const reveals = document.querySelectorAll(".reveal");
            reveals.forEach(el => {
                const rect = el.getBoundingClientRect();
                if (rect.top < window.innerHeight - 50) {
                    el.classList.add("active");
                    // On active aussi les sous-éléments
                    el.querySelectorAll(".reveal").forEach(child => child.classList.add("active"));
                }
            });
        }

        document.addEventListener("turbo:load", handleReveal);
        document.addEventListener("turbo:render", handleReveal);
        document.addEventListener("DOMContentLoaded", handleReveal);

        window.addEventListener("pageshow", (event) => {
            handleReveal();
            setTimeout(handleReveal, 500);
            setTimeout(handleReveal, 1000);
        });

        window.addEventListener("scroll", handleReveal);

        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                const targetId = this.getAttribute('href');
                const targetElement = document.querySelector(targetId);

                if (targetElement) {
                    e.preventDefault();

                    // Calcul précis de la position de la section
                    const navbarHeight = 80;
                    const elementPosition = targetElement.offsetTop;
                    const offsetPosition = elementPosition - navbarHeight;

                    window.scrollTo({
                        top: offsetPosition,
                        behavior: "smooth"
                    });

                    // Force l'affichage des éléments Reveal de cette section
                    setTimeout(() => {
                        targetElement.classList.add("active");
                        targetElement.querySelectorAll(".reveal").forEach(el => el.classList.add("active"));
                    }, 400); // On attend que le scroll soit bien engagé
                }
            });
        });

        function copyEmail() {
            navigator.clipboard.writeText("maudkau@gmail.com").then(() => {
                const msg = document.getElementById('copy-success');
                if(msg) {
                    msg.style.display = 'block';
                    setTimeout(() => msg.style.display = 'none', 3000);
                }
            });
        }
    </script>
{% endblock %}
</body>
</html>
